{
  "manifest_version": 3,
  "name": "ANINAG AI",
  "version": "1.0",
  "description": "Floating Svelte panel",
  "permissions": ["scripting"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["dist/assets/*", "dist/index.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
