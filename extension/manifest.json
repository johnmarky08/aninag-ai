{
  "manifest_version": 3,
  "name": "ANINAG AI",
  "version": "1.0.0",
  "description": "AI-powered news analysis and bias detection for social media posts.",
  "permissions": ["scripting"],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "host_permissions": [
    "https://*.facebook.com/*",
    "https://*.twitter.com/*",
    "https://*.x.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*.facebook.com/*",
        "https://*.twitter.com/*",
        "https://*.x.com/*"
      ],
      "js": ["content.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["dist/assets/*", "dist/index.html"],
      "matches": [
        "https://*.facebook.com/*",
        "https://*.twitter.com/*",
        "https://*.x.com/*"
      ]
    }
  ]
}
